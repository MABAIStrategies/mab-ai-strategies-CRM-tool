generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

enum DealStage {
  PROSPECTING
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum DealStatus {
  OPEN
  WON
  LOST
  STALLED
}

enum ActivityType {
  CALL
  EMAIL
  MEETING
  DEMO
  NOTE
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum AssetType {
  DOCUMENT
  PRESENTATION
  SPREADSHEET
  IMAGE
  VIDEO
  LINK
  OTHER
}

enum TemplateType {
  EMAIL
  PROPOSAL
  FOLLOW_UP
  SEQUENCE
  OTHER
}

enum MemorySourceType {
  CALL_SUMMARY
  EMAIL
  MEETING
  NOTE
  TASK
  IMPORT
  OTHER
}

enum JobType {
  SUMMARIZE
  EXTRACT
  EMBED
  DRAFT
  NOTIFY
  OTHER
}

enum JobStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

model Company {
  id           String       @id @default(uuid()) @db.Uuid
  name         String
  website      String?
  industry     String?
  size         Int?
  description  String?
  phone        String?
  email        String?
  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  postalCode   String?
  country      String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  contacts     Contact[]
  deals        Deal[]
  activities   Activity[]
  notes        Note[]
  tasks        Task[]
  assets       Asset[]
  templates    Template[]
  memoryItems  MemoryItem[]
  jobs         Job[]
}

model Contact {
  id          String       @id @default(uuid()) @db.Uuid
  companyId   String?      @db.Uuid
  firstName   String
  lastName    String
  email       String?
  phone       String?
  title       String?
  linkedinUrl String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  company     Company?     @relation(fields: [companyId], references: [id])
  deals       Deal[]
  activities  Activity[]
  notes       Note[]
  tasks       Task[]
  memoryItems MemoryItem[]

  @@index([companyId])
  @@index([email])
  @@index([lastName, firstName])
}

model Deal {
  id                String       @id @default(uuid()) @db.Uuid
  companyId         String?      @db.Uuid
  contactId         String?      @db.Uuid
  name              String
  description       String?
  value             Decimal?     @db.Decimal(12, 2)
  currency          String       @default("USD")
  stage             DealStage    @default(PROSPECTING)
  status            DealStatus   @default(OPEN)
  expectedCloseDate DateTime?
  closedAt          DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  company           Company?     @relation(fields: [companyId], references: [id])
  primaryContact    Contact?     @relation(fields: [contactId], references: [id])
  activities        Activity[]
  notes             Note[]
  tasks             Task[]
  memoryItems       MemoryItem[]

  @@index([companyId])
  @@index([contactId])
  @@index([stage])
  @@index([status])
}

model Activity {
  id          String       @id @default(uuid()) @db.Uuid
  companyId   String?      @db.Uuid
  contactId   String?      @db.Uuid
  dealId      String?      @db.Uuid
  type        ActivityType
  title       String
  description String?
  occurredAt  DateTime     @default(now())
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  company     Company?     @relation(fields: [companyId], references: [id])
  contact     Contact?     @relation(fields: [contactId], references: [id])
  deal        Deal?        @relation(fields: [dealId], references: [id])
  notes       Note[]
  memoryItems MemoryItem[]

  @@index([companyId])
  @@index([contactId])
  @@index([dealId])
  @@index([occurredAt])
}

model Note {
  id         String    @id @default(uuid()) @db.Uuid
  companyId  String?   @db.Uuid
  contactId  String?   @db.Uuid
  dealId     String?   @db.Uuid
  activityId String?   @db.Uuid
  title      String?
  body       String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  company    Company?  @relation(fields: [companyId], references: [id])
  contact    Contact?  @relation(fields: [contactId], references: [id])
  deal       Deal?     @relation(fields: [dealId], references: [id])
  activity   Activity? @relation(fields: [activityId], references: [id])
  memoryItems MemoryItem[]

  @@index([companyId])
  @@index([contactId])
  @@index([dealId])
  @@index([activityId])
}

model Task {
  id          String       @id @default(uuid()) @db.Uuid
  companyId   String?      @db.Uuid
  contactId   String?      @db.Uuid
  dealId      String?      @db.Uuid
  activityId  String?      @db.Uuid
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  company     Company?     @relation(fields: [companyId], references: [id])
  contact     Contact?     @relation(fields: [contactId], references: [id])
  deal        Deal?        @relation(fields: [dealId], references: [id])
  activity    Activity?    @relation(fields: [activityId], references: [id])
  memoryItems MemoryItem[]

  @@index([companyId])
  @@index([contactId])
  @@index([dealId])
  @@index([activityId])
  @@index([status])
}

model Asset {
  id          String    @id @default(uuid()) @db.Uuid
  companyId   String?   @db.Uuid
  name        String
  type        AssetType @default(DOCUMENT)
  description String?
  url         String
  mimeType    String?
  sizeBytes   Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  company     Company?  @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([type])
}

model Template {
  id          String       @id @default(uuid()) @db.Uuid
  companyId   String?      @db.Uuid
  name        String
  type        TemplateType @default(EMAIL)
  subject     String?
  body        String
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  company     Company?     @relation(fields: [companyId], references: [id])
  memoryItems MemoryItem[]

  @@index([companyId])
  @@index([type])
}

model MemoryItem {
  id          String           @id @default(uuid()) @db.Uuid
  companyId   String?          @db.Uuid
  contactId   String?          @db.Uuid
  dealId      String?          @db.Uuid
  activityId  String?          @db.Uuid
  taskId      String?          @db.Uuid
  noteId      String?          @db.Uuid
  templateId  String?          @db.Uuid
  title       String?
  content     String
  sourceType  MemorySourceType @default(OTHER)
  sourceId    String?
  embedding   Unsupported("vector")?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  company     Company?         @relation(fields: [companyId], references: [id])
  contact     Contact?         @relation(fields: [contactId], references: [id])
  deal        Deal?            @relation(fields: [dealId], references: [id])
  activity    Activity?        @relation(fields: [activityId], references: [id])
  task        Task?            @relation(fields: [taskId], references: [id])
  note        Note?            @relation(fields: [noteId], references: [id])
  template    Template?        @relation(fields: [templateId], references: [id])

  @@index([companyId])
  @@index([contactId])
  @@index([dealId])
  @@index([activityId])
  @@index([taskId])
  @@index([noteId])
  @@index([templateId])
}

model Job {
  id          String     @id @default(uuid()) @db.Uuid
  companyId   String?    @db.Uuid
  type        JobType
  status      JobStatus  @default(PENDING)
  payload     Json
  result      Json?
  errorMessage String?
  attempts    Int        @default(0)
  maxAttempts Int        @default(3)
  runAt       DateTime   @default(now())
  startedAt   DateTime?
  finishedAt  DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  company     Company?   @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([status])
  @@index([type])
  @@index([runAt])
}
