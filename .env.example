# Database — use Neon (neon.tech) for production
DATABASE_URL="postgresql://mab:mab@localhost:5432/mab_crm"

# App
APP_URL="http://localhost:3000"

# Auth
PASSCODE="mab"
PASSCODE_HASH=""
AUTH_SECRET="change-me-in-prod"

# AI — set OPENAI_API_KEY to enable real AI features (otherwise uses smart mock)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# AI Rate Limits
AI_RATE_LIMIT_PER_MINUTE="30"
AI_MAX_RETRIES="3"
AI_BACKOFF_MS="1000"
AI_COST_PER_1K_TOKENS="0.002"

# Email — set RESEND_API_KEY to enable outreach sending
RESEND_API_KEY=""
FROM_EMAIL="outreach@yourdomain.com"

# Local Postgres (for docker-compose)
POSTGRES_USER=mab
POSTGRES_PASSWORD=mab
POSTGRES_DB=mab_crm

# Google Workspace MCP sync (Gmail + Calendar)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/integrations/google/callback"
